{% comment %}
  Renders one trust feature card. Accepts: block
  End-to-end: icon "route" (preset) or block setting end_to_end_card.
{% endcomment %}
{%- liquid
  assign is_end_to_end = false
  if block.settings.end_to_end_card
    assign is_end_to_end = true
  elsif block.settings.icon == 'route'
    assign is_end_to_end = true
  endif
  assign is_horeca = false
  if block.settings.horeca_wide_card
    assign is_horeca = true
  elsif block.settings.icon == 'horeca'
    assign is_horeca = true
  endif
-%}
<article
  class="{% if is_end_to_end %}end-to-end-solutions{% else %}about-fl-trust__card{% endif %}{% if is_horeca %} horeca-card{% endif %}"
  {{ block.shopify_attributes }}
>
  <div class="about-fl-trust__card-icon">
    {%- if block.settings.custom_icon != blank -%}
      {%- assign card_icon_alt = block.settings.title | default: 'Feature' | strip | escape -%}
      {{
        block.settings.custom_icon
        | image_url: width: 96
        | image_tag: loading: 'lazy', widths: '48, 96', alt: card_icon_alt
      }}
    {%- else -%}
      {% render 'about-fl-card-icon', icon: block.settings.icon %}
    {%- endif -%}
  </div>
  {%- if block.settings.title != blank -%}
    <h3 class="about-fl-trust__card-title">{{ block.settings.title | escape }}</h3>
  {%- endif -%}
  {%- if block.settings.text != blank -%}
    <div class="about-fl-trust__card-text rte">{{ block.settings.text }}</div>
  {%- endif -%}
</article>
