{{ 'section-about-foodlink.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #about-fl-trust-{{ section.id }} {
    --about-fl-navy: {{ section.settings.navy_color }};
    --about-fl-teal: {{ section.settings.teal_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #about-fl-trust-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section id="about-fl-trust-{{ section.id }}" class="about-fl-trust section-{{ section.id }}">
  <div class="about-fl-trust__inner">
    <header class="about-fl-trust__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="about-fl-trust__eyebrow">
          {%- if section.settings.show_eyebrow_icon -%}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 15a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" stroke-width="1.6"/>
              <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 008.6 15a1.65 1.65 0 00-1-1.51V13a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 15z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="about-fl-trust__title {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </header>

    {%- liquid
      assign about_fl_feature_count = 0
      for block in section.blocks
        if block.type == 'feature'
          assign about_fl_feature_count = about_fl_feature_count | plus: 1
        endif
      endfor
    -%}
    {%- if about_fl_feature_count > 0 -%}
      <div class="about-fl-trust__rows">
        <div class="about-fl-trust__row about-fl-trust__row--3">
          {%- assign about_fl_row1 = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              {%- if about_fl_row1 == 3 -%}
                {%- break -%}
              {%- endif -%}
              {% render 'about-fl-feature-card', block: block %}
              {%- assign about_fl_row1 = about_fl_row1 | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- if about_fl_feature_count > 3 -%}
          <div class="about-fl-trust__row about-fl-trust__row--2">
            {%- assign about_fl_seen = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature' -%}
                {%- if about_fl_seen < 3 -%}
                  {%- assign about_fl_seen = about_fl_seen | plus: 1 -%}
                {%- else -%}
                  {% render 'about-fl-feature-card', block: block %}
                  {%- assign about_fl_seen = about_fl_seen | plus: 1 -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_show -%}
      <div class="about-fl-trust__cta">
        <div class="about-fl-trust__cta-visual">
          <div class="about-fl-trust__cta-avatars" aria-hidden="true">
            {%- if section.settings.cta_avatar_1 != blank -%}
              <div class="about-fl-trust__cta-avatar">
                {{ section.settings.cta_avatar_1 | image_url: width: 128 | image_tag: loading: 'lazy', widths: '64, 128' }}
              </div>
            {%- endif -%}
            {%- if section.settings.cta_avatar_2 != blank -%}
              <div class="about-fl-trust__cta-avatar">
                {{ section.settings.cta_avatar_2 | image_url: width: 128 | image_tag: loading: 'lazy', widths: '64, 128' }}
              </div>
            {%- endif -%}
          </div>
          <div class="about-fl-trust__cta-stat">
            {%- if section.settings.cta_stat != blank -%}
              <div class="about-fl-trust__cta-stat-line rte">{{ section.settings.cta_stat }}</div>
            {%- endif -%}
            {%- if section.settings.cta_stat_sub != blank -%}
              <p class="about-fl-trust__cta-stat-sub">{{ section.settings.cta_stat_sub | escape }}</p>
            {%- endif -%}
          </div>
        </div>
        <div class="about-fl-trust__cta-right">
          {%- if section.settings.cta_copy != blank -%}
            <div class="about-fl-trust__cta-copy rte">{{ section.settings.cta_copy }}</div>
          {%- endif -%}
          {%- if section.settings.cta_button_label != blank -%}
            {%- liquid
              assign cta_href = section.settings.cta_button_link
              if cta_href == blank
                assign cta_href = '#'
              endif
            -%}
            <a
              class="about-fl-trust__cta-btn"
              href="{{ cta_href }}"
              {% if section.settings.cta_button_link == blank %}
                role="link" aria-disabled="true"
              {% endif %}
            >
              {{ section.settings.cta_button_label | escape }}
              <span class="svg-wrapper">{{ 'icon-arrow.svg' | inline_asset_content }}</span>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "About — Food Link trust",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_eyebrow_icon",
      "label": "Show icon next to eyebrow",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "WHAT WE OFFER FOR YOU"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why brands trust food link"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Large" },
        { "value": "h1", "label": "Extra large" },
        { "value": "h0", "label": "Display" }
      ],
      "default": "h1"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "navy_color",
      "label": "Section background (navy)",
      "default": "#061a2e"
    },
    {
      "type": "color",
      "id": "teal_color",
      "label": "CTA banner color (teal)",
      "default": "#0a6b72"
    },
    {
      "type": "header",
      "content": "CTA banner"
    },
    {
      "type": "checkbox",
      "id": "cta_show",
      "label": "Show CTA banner",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "cta_avatar_1",
      "label": "CTA overlapping image 1"
    },
    {
      "type": "image_picker",
      "id": "cta_avatar_2",
      "label": "CTA overlapping image 2"
    },
    {
      "type": "richtext",
      "id": "cta_stat",
      "label": "CTA headline (e.g. stats)",
      "default": "<p><strong>95+</strong> Connecting global brands to the gulf</p>"
    },
    {
      "type": "text",
      "id": "cta_stat_sub",
      "label": "CTA subline",
      "default": "Your universal path to success"
    },
    {
      "type": "richtext",
      "id": "cta_copy",
      "label": "CTA supporting text",
      "default": "<p>Our team is here to answer your questions and help you get started on turning your vision into reality.</p>"
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "Button label",
      "default": "Get Started"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "hands", "label": "Partnership" },
            { "value": "branches", "label": "Network" },
            { "value": "layers", "label": "Layers / retail" },
            { "value": "route", "label": "End-to-end" },
            { "value": "horeca", "label": "Hospitality" }
          ],
          "default": "hands"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon (optional)",
          "info": "Replaces the selected icon when an image is set."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Short supporting copy for this strength.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About — Food Link trust",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "hands",
            "title": "Decades of experience",
            "text": "<p>Deep category knowledge and long-standing relationships across retail and foodservice.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "branches",
            "title": "Strong regional networks",
            "text": "<p>On-the-ground coverage and trusted channels that accelerate listings and distribution.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "layers",
            "title": "Retail differentiation",
            "text": "<p>Merchandising, positioning, and activation that help brands stand out on shelf and online.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "route",
            "title": "End-to-end solutions",
            "text": "<p>From import to shelf: regulatory, logistics, and go-to-market support in one coordinated team.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "horeca",
            "title": "HORECA",
            "text": "<p>Dedicated reach into hotels, restaurants, and cafés with tailored programs for operators.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
